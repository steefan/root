# Supabase — from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used by the proactive cron.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway — routes chat + embeddings via "provider/model" strings.
# Create at https://vercel.com/dashboard → AI Gateway. Auto-injected on Vercel.
AI_GATEWAY_API_KEY=

# OpenAI — used directly for voice (Whisper STT + TTS). Not routed via gateway.
OPENAI_API_KEY=

# Protects the /api/cron/proactive route. Generate any long random string.
CRON_SECRET=
